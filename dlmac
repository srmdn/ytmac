#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
DOWNLOAD_DIR="downloads"

usage() {
  cat <<EOF
dlmac v${VERSION} — macOS CLI for yt-dlp and ffmpeg

Usage:
  dlmac info <url>                    Show video metadata
  dlmac formats <url>                 Show available formats
  dlmac video <url>                   Download best video (mp4)
  dlmac video <url> --quality 720p    Download best video up to 720p
  dlmac video <url> --quality 1080p   Download best video up to 1080p
  dlmac audio <url>                   Download best audio (mp3)
  dlmac audio <url> --format mp3      Download audio as mp3
  dlmac audio <url> --format m4a      Download audio as m4a
  dlmac audio <url> --format wav      Download audio as wav
  dlmac convert <file> --to mp3       Extract audio from video to mp3
  dlmac convert <file> --to m4a       Extract audio from video to m4a
  dlmac convert <file> --to wav       Extract audio from video to wav

Requirements: yt-dlp, ffmpeg (install via Homebrew)
Output: ./downloads/
EOF
  exit "${1:-0}"
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" &>/dev/null; then
    echo "dlmac: '$cmd' not found."
    echo "Install with: brew install $cmd"
    exit 1
  fi
}

cmd_info() {
  if [[ $# -eq 0 ]]; then
    echo "dlmac: missing URL"
    echo "Usage: dlmac info <url>"
    exit 1
  fi

  require_cmd yt-dlp
  yt-dlp --print title --print duration --print uploader "$1"
}

cmd_formats() {
  if [[ $# -eq 0 ]]; then
    echo "dlmac: missing URL"
    echo "Usage: dlmac formats <url>"
    exit 1
  fi

  require_cmd yt-dlp
  yt-dlp -F "$1"
}

cmd_video() {
  if [[ $# -eq 0 ]]; then
    echo "dlmac: missing URL"
    echo "Usage: dlmac video <url> [--quality 720p|1080p]"
    exit 1
  fi

  local url="$1"
  shift

  local quality_format="bv*+ba/b"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --quality)
        if [[ -z "${2:-}" ]]; then
          echo "dlmac: --quality requires a value"
          echo "Valid values: 720p, 1080p"
          exit 1
        fi
        case "$2" in
          720p)  quality_format="bv*[height<=720]+ba/b[height<=720]" ;;
          1080p) quality_format="bv*[height<=1080]+ba/b[height<=1080]" ;;
          *)
            echo "dlmac: unsupported quality '$2'"
            echo "Valid values: 720p, 1080p"
            exit 1
            ;;
        esac
        shift 2
        ;;
      *)
        echo "dlmac: unknown option '$1'"
        echo "Usage: dlmac video <url> [--quality 720p|1080p]"
        exit 1
        ;;
    esac
  done

  require_cmd yt-dlp
  require_cmd ffmpeg

  mkdir -p "$DOWNLOAD_DIR"

  yt-dlp \
    -f "$quality_format" \
    --merge-output-format mp4 \
    -o "${DOWNLOAD_DIR}/%(title)s.%(ext)s" \
    "$url"
}

main() {
  if [[ $# -eq 0 ]]; then
    usage 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    info)
      cmd_info "$@"
      ;;
    formats)
      cmd_formats "$@"
      ;;
    video)
      cmd_video "$@"
      ;;
    audio|convert)
      echo "dlmac: '$cmd' not implemented yet (v${VERSION})"
      exit 0
      ;;
    -h|--help)
      usage 0
      ;;
    *)
      echo "dlmac: unknown command '$cmd'"
      usage 1
      ;;
  esac
}

main "$@"
