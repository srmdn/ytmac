#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
DOWNLOAD_DIR="downloads"

usage() {
  cat <<EOF
dlmac v${VERSION} — macOS CLI for yt-dlp and ffmpeg

Usage:
  dlmac info <url>                    Show video metadata
  dlmac formats <url>                 Show available formats
  dlmac video <url>                   Download best video (mp4)
  dlmac video <url> --quality 360p    Download best video up to 360p
  dlmac video <url> --quality 480p    Download best video up to 480p
  dlmac video <url> --quality 720p    Download best video up to 720p
  dlmac video <url> --quality 1080p   Download best video up to 1080p
  dlmac audio <url>                   Download best audio (mp3)
  dlmac audio <url> --format mp3      Download audio as mp3
  dlmac audio <url> --format m4a      Download audio as m4a
  dlmac audio <url> --format wav      Download audio as wav
  dlmac convert <file> --to mp3       Extract audio from video to mp3
  dlmac convert <file> --to m4a       Extract audio from video to m4a
  dlmac convert <file> --to wav       Extract audio from video to wav

Requirements: yt-dlp, ffmpeg (install via Homebrew)
Output: ./downloads/
EOF
  exit "${1:-0}"
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" &>/dev/null; then
    echo "dlmac: '$cmd' not found."
    echo "Install with: brew install $cmd"
    exit 1
  fi
}

cmd_info() {
  if [[ $# -eq 0 ]]; then
    echo "dlmac: missing URL"
    echo "Usage: dlmac info <url>"
    exit 1
  fi

  if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: dlmac info <url>"
    echo "Show video metadata (title, duration, uploader)."
    exit 0
  fi

  require_cmd yt-dlp
  yt-dlp --print title --print duration --print uploader "$1"
}

cmd_formats() {
  if [[ $# -eq 0 ]]; then
    echo "dlmac: missing URL"
    echo "Usage: dlmac formats <url>"
    exit 1
  fi

  if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: dlmac formats <url>"
    echo "Show available download formats."
    exit 0
  fi

  require_cmd yt-dlp
  yt-dlp -F "$1"
}

cmd_video() {
  if [[ $# -eq 0 ]]; then
    echo "dlmac: missing URL"
    echo "Usage: dlmac video <url> [--quality 360p|480p|720p|1080p]"
    exit 1
  fi

  if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: dlmac video <url> [--quality 360p|480p|720p|1080p]"
    echo "Download best video+audio merged to mp4 (H.264, QuickTime-compatible)."
    exit 0
  fi

  local url="$1"
  shift

  local quality=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --quality)
        if [[ -z "${2:-}" ]]; then
          echo "dlmac: --quality requires a value"
          echo "Valid values: 360p, 480p, 720p, 1080p"
          exit 1
        fi
        quality="$2"
        shift 2
        ;;
      *)
        echo "dlmac: unknown option '$1'"
        echo "Usage: dlmac video <url> [--quality 360p|480p|720p|1080p]"
        exit 1
        ;;
    esac
  done

  # Build format string preferring H.264+AAC (QuickTime-compatible)
  # Falls back to any format if H.264 unavailable
  local fmt
  if [[ -n "$quality" ]]; then
    local max_height="${quality%p}"
    case "$quality" in
      360p)  max_height=360 ;;
      480p)  max_height=480 ;;
      720p)  max_height=720 ;;
      1080p) max_height=1080 ;;
      *)
        echo "dlmac: unsupported quality '$quality'"
        echo "Valid values: 360p, 480p, 720p, 1080p"
        exit 1
        ;;
    esac
    fmt="bestvideo[vcodec^=avc][height<=${max_height}]+bestaudio[ext=m4a]/bestvideo[vcodec^=avc][height<=${max_height}]+bestaudio/bv*[height<=${max_height}]+ba/b[height<=${max_height}]"
  else
    fmt="bestvideo[vcodec^=avc]+bestaudio[ext=m4a]/bestvideo[vcodec^=avc]+bestaudio/bv*+ba/b"
  fi

  require_cmd yt-dlp
  require_cmd ffmpeg
  require_cmd ffprobe

  mkdir -p "$DOWNLOAD_DIR"

  local output_pattern="${DOWNLOAD_DIR}/%(title)s.%(ext)s"

  # Predict output filename so we can check codec after download
  local predicted_file
  predicted_file=$(yt-dlp --get-filename -f "$fmt" --merge-output-format mp4 -o "$output_pattern" "$url" 2>/dev/null) || true

  yt-dlp \
    -f "$fmt" \
    --merge-output-format mp4 \
    -o "$output_pattern" \
    "$url"

  # QuickTime needs H.264 video + AAC audio. If yt-dlp fell back to
  # incompatible codecs (VP9 video or Opus audio), re-encode with ffmpeg.
  if [[ -n "$predicted_file" && -f "$predicted_file" ]]; then
    local vcodec acodec
    vcodec=$(ffprobe -v error -select_streams v:0 -show_entries stream=codec_name -of default=noprint_wrappers=1:nokey=1 "$predicted_file" 2>/dev/null || echo "")
    acodec=$(ffprobe -v error -select_streams a:0 -show_entries stream=codec_name -of default=noprint_wrappers=1:nokey=1 "$predicted_file" 2>/dev/null || echo "")
    if [[ "$vcodec" != "h264" || "$acodec" != "aac" ]]; then
      echo "Re-encoding to H.264+AAC for QuickTime compatibility..."
      local temp="${predicted_file}.recode.mp4"
      if ffmpeg -i "$predicted_file" -c:v libx264 -preset fast -crf 23 -c:a aac -b:a 128k -movflags +faststart -y "$temp" 2>/dev/null; then
        mv "$temp" "$predicted_file"
        echo "Done: $predicted_file"
      else
        echo "dlmac: re-encode failed, removing partial file"
        rm -f "$temp"
        exit 1
      fi
    fi
  fi
}

cmd_audio() {
  if [[ $# -eq 0 ]]; then
    echo "dlmac: missing URL"
    echo "Usage: dlmac audio <url> [--format mp3|m4a|wav]"
    exit 1
  fi

  if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: dlmac audio <url> [--format mp3|m4a|wav]"
    echo "Download best audio, default mp3."
    exit 0
  fi

  local url="$1"
  shift

  local audio_format="mp3"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --format)
        if [[ -z "${2:-}" ]]; then
          echo "dlmac: --format requires a value"
          echo "Valid values: mp3, m4a, wav"
          exit 1
        fi
        case "$2" in
          mp3|m4a|wav) audio_format="$2" ;;
          *)
            echo "dlmac: unsupported format '$2'"
            echo "Valid values: mp3, m4a, wav"
            exit 1
            ;;
        esac
        shift 2
        ;;
      *)
        echo "dlmac: unknown option '$1'"
        echo "Usage: dlmac audio <url> [--format mp3|m4a|wav]"
        exit 1
        ;;
    esac
  done

  require_cmd yt-dlp
  require_cmd ffmpeg

  mkdir -p "$DOWNLOAD_DIR"

  local extra_args=()
  if [[ "$audio_format" == "mp3" ]]; then
    extra_args=(--audio-quality 0)
  fi

  yt-dlp \
    -f "bestaudio" \
    -x \
    --audio-format "$audio_format" \
    "${extra_args[@]}" \
    -o "${DOWNLOAD_DIR}/%(title)s.%(ext)s" \
    "$url"
}

cmd_convert() {
  if [[ $# -gt 0 && ("$1" == "--help" || "$1" == "-h") ]]; then
    echo "Usage: dlmac convert <file> --to mp3|m4a|wav"
    echo "Extract audio from local video file."
    exit 0
  fi

  if [[ $# -lt 2 ]]; then
    echo "dlmac: missing arguments"
    echo "Usage: dlmac convert <file> --to mp3|m4a|wav"
    exit 1
  fi

  local input_file="$1"
  shift

  local output_format=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)
        if [[ -z "${2:-}" ]]; then
          echo "dlmac: --to requires a value"
          echo "Valid values: mp3, m4a, wav"
          exit 1
        fi
        case "$2" in
          mp3|m4a|wav) output_format="$2" ;;
          *)
            echo "dlmac: unsupported format '$2'"
            echo "Valid values: mp3, m4a, wav"
            exit 1
            ;;
        esac
        shift 2
        ;;
      *)
        echo "dlmac: unknown option '$1'"
        echo "Usage: dlmac convert <file> --to mp3|m4a|wav"
        exit 1
        ;;
    esac
  done

  if [[ -z "$output_format" ]]; then
    echo "dlmac: missing --to flag"
    echo "Usage: dlmac convert <file> --to mp3|m4a|wav"
    exit 1
  fi

  if [[ ! -f "$input_file" ]]; then
    echo "dlmac: file not found: $input_file"
    exit 1
  fi

  require_cmd ffmpeg

  mkdir -p "$DOWNLOAD_DIR"

  local basename
  basename="$(basename "$input_file")"
  basename="${basename%.*}"
  local output_file="${DOWNLOAD_DIR}/${basename}.${output_format}"

  if [[ -f "$output_file" ]]; then
    echo "dlmac: output file already exists: $output_file"
    echo "Remove it first or rename the input file."
    exit 1
  fi

  case "$output_format" in
    mp3)
      ffmpeg -i "$input_file" -vn -acodec libmp3lame -q:a 2 "$output_file"
      ;;
    m4a)
      ffmpeg -i "$input_file" -vn -c:a aac -b:a 192k "$output_file"
      ;;
    wav)
      ffmpeg -i "$input_file" -vn "$output_file"
      ;;
  esac

  echo "Converted: $output_file"
}

main() {
  if [[ $# -eq 0 ]]; then
    usage 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    info)
      cmd_info "$@"
      ;;
    formats)
      cmd_formats "$@"
      ;;
    video)
      cmd_video "$@"
      ;;
    audio)
      cmd_audio "$@"
      ;;
    convert)
      cmd_convert "$@"
      ;;
    -h|--help)
      usage 0
      ;;
    --version)
      echo "dlmac v${VERSION}"
      exit 0
      ;;
    *)
      echo "dlmac: unknown command '$cmd'"
      usage 1
      ;;
  esac
}

main "$@"
