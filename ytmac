#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
DOWNLOAD_DIR="downloads"

usage() {
  cat <<EOF
ytmac v${VERSION} — macOS CLI for yt-dlp and ffmpeg

Usage:
  ytmac info <url>                    Show video metadata
  ytmac formats <url>                 Show available formats
  ytmac video <url>                   Download best video (mp4)
  ytmac video <url> --quality 720p    Download best video up to 720p
  ytmac video <url> --quality 1080p   Download best video up to 1080p
  ytmac audio <url>                   Download best audio (mp3)
  ytmac audio <url> --format mp3      Download audio as mp3
  ytmac audio <url> --format m4a      Download audio as m4a
  ytmac audio <url> --format wav      Download audio as wav
  ytmac convert <file> --to mp3       Extract audio from video to mp3
  ytmac convert <file> --to m4a       Extract audio from video to m4a
  ytmac convert <file> --to wav       Extract audio from video to wav

Requirements: yt-dlp, ffmpeg (install via Homebrew)
Output: ./downloads/
EOF
  exit "${1:-0}"
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" &>/dev/null; then
    echo "ytmac: '$cmd' not found."
    echo "Install with: brew install $cmd"
    exit 1
  fi
}

cmd_info() {
  if [[ $# -eq 0 ]]; then
    echo "ytmac: missing URL"
    echo "Usage: ytmac info <url>"
    exit 1
  fi

  require_cmd yt-dlp
  yt-dlp --print title --print duration --print uploader "$1"
}

cmd_formats() {
  if [[ $# -eq 0 ]]; then
    echo "ytmac: missing URL"
    echo "Usage: ytmac formats <url>"
    exit 1
  fi

  require_cmd yt-dlp
  yt-dlp -F "$1"
}

cmd_video() {
  if [[ $# -eq 0 ]]; then
    echo "ytmac: missing URL"
    echo "Usage: ytmac video <url> [--quality 720p|1080p]"
    exit 1
  fi

  require_cmd yt-dlp
  require_cmd ffmpeg

  mkdir -p "$DOWNLOAD_DIR"

  yt-dlp \
    -f "bv*+ba/b" \
    --merge-output-format mp4 \
    -o "${DOWNLOAD_DIR}/%(title)s.%(ext)s" \
    "$1"
}

main() {
  if [[ $# -eq 0 ]]; then
    usage 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    info)
      cmd_info "$@"
      ;;
    formats)
      cmd_formats "$@"
      ;;
    video)
      cmd_video "$@"
      ;;
    audio|convert)
      echo "ytmac: '$cmd' not implemented yet (v${VERSION})"
      exit 0
      ;;
    -h|--help)
      usage 0
      ;;
    *)
      echo "ytmac: unknown command '$cmd'"
      usage 1
      ;;
  esac
}

main "$@"
